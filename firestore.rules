
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow get, create, update: if isOwner(userId);
      allow list: if false; // Chỉ Admin mới được list, nhưng ở đây dùng quy tắc đơn giản cho MVP

      match /paymentGatewayConfigurations/{configId} {
        allow read, write: if isOwner(userId);
      }

      match /gmailListenerConfigurations/{configId} {
        allow read, write: if isOwner(userId);
      }

      match /webhookConfigurations/{configId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
