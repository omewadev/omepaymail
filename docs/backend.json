
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Thông tin hồ sơ người dùng bao gồm hạn mức giao dịch và gói cước.",
      "properties": {
        "id": {
          "type": "string",
          "description": "UID của người dùng từ Firebase Auth."
        },
        "displayName": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "planName": {
          "type": "string",
          "enum": ["Free", "Pro", "Enterprise"]
        },
        "transactionLimit": {
          "type": "number",
          "description": "Số lượng giao dịch tối đa trong tháng."
        },
        "transactionCount": {
          "type": "number",
          "description": "Số lượng giao dịch đã thực hiện trong tháng hiện tại."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "email", "planName", "transactionLimit", "transactionCount"]
    },
    "PaymentGatewayConfiguration": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PaymentGatewayConfiguration",
      "type": "object",
      "description": "Cấu hình cổng thanh toán.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "gatewayType": { "type": "string" },
        "apiKey": { "type": "string" },
        "merchantId": { "type": "string" },
        "currency": { "type": "string" },
        "isEnabled": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "gatewayType", "merchantId", "currency", "isEnabled"]
    },
    "GmailListenerConfiguration": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "GmailListenerConfiguration",
      "type": "object",
      "description": "Cấu hình lắng nghe Gmail.",
      "properties": {
        "id": { "type": "string" },
        "monitoredEmailAddress": { "type": "string", "format": "email" },
        "bankSenderEmailPatterns": { "type": "array", "items": { "type": "string" } },
        "confirmationKeywords": { "type": "array", "items": { "type": "string" } },
        "isEnabled": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "monitoredEmailAddress", "isEnabled"]
    },
    "WebhookConfiguration": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "WebhookConfiguration",
      "type": "object",
      "description": "Cấu hình Webhook gửi về Merchant.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "targetUrl": { "type": "string", "format": "uri" },
        "secretToken": { "type": "string" },
        "referencePrefix": { "type": "string", "description": "Tiền tố mã đơn hàng (ví dụ: TT, CG, DH)." },
        "triggerEvent": { "type": "string" },
        "isEnabled": { "type": "boolean" },
        "retryAttempts": { "type": "number" },
        "retryIntervalSeconds": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "targetUrl", "isEnabled", "referencePrefix"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Thông tin hồ sơ và hạn mức của người dùng."
    },
    "/users/{userId}/paymentGatewayConfigurations/{id}": {
      "schema": { "$ref": "#/backend/entities/PaymentGatewayConfiguration" },
      "description": "Cấu hình cổng thanh toán cá nhân."
    },
    "/users/{userId}/gmailListenerConfigurations/{id}": {
      "schema": { "$ref": "#/backend/entities/GmailListenerConfiguration" },
      "description": "Cấu hình Gmail Listener cá nhân."
    },
    "/users/{userId}/webhookConfigurations/{id}": {
      "schema": { "$ref": "#/backend/entities/WebhookConfiguration" },
      "description": "Cấu hình Webhook cá nhân gửi về WordPress hoặc Custom Web."
    }
  }
}
