      priceNumber: 0,
      limit: "Không giới hạn",
      features:["Website không giới hạn", "API riêng biệt", "Tư vấn tích hợp", "SLA 99.9%"],
      icon: Crown,
      color: "bg-amber-100 text-amber-600"
