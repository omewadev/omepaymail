<file path="firestore.rules">
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // [BẢN VÁ LỖI] - Thêm kiểm tra an toàn và đổi nội dung để ép Firebase CLI upload lại
    function isSuperAdmin() {
      return request.auth != null && 
             request.auth.token != null && 
             'email' in request.auth.token && 
             request.auth.token.email == 'omewadev@gmail.com';
    }

    // 1. Bảng users và TẤT CẢ các sub-collections bên trong
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      
      match /webhookConfigurations/{docId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      }
      match /gmailListenerConfigurations/{docId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      }
      match /webhook_logs/{docId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      }
      match /emails/{docId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      }
    }

    // 2. Bảng system_settings
    match /system_settings/{document} {
      allow read: if true; 
      allow write: if isSuperAdmin(); 
    }

    // 3. Cho phép Admin query Collection Group (Trang Lịch sử toàn hệ thống)
    match /{path=**}/webhook_logs/{logId} {
      allow read: if isSuperAdmin();
    }
  }
}
